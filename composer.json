{
    "name": "durable-workflow/workflow",
    "description": "Embedded durable workflow runtime and orchestration engine for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "replace": {
        "laravel-workflow/laravel-workflow": "self.version"
    },
    "autoload": {
        "psr-4": {
            "Workflow\\": "src/"
        },
        "files": [
            "src/functions.php",
            "src/V2/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "ecs": "vendor/bin/ecs check --fix",
        "stan": "vendor/bin/phpstan analyse src tests",
        "feature": [
            "Composer\\Config::disableProcessTimeout",
            "phpunit --testdox --testsuite feature"
        ],
        "unit": "phpunit --testdox --testsuite unit",
        "test": "phpunit --testdox",
        "coverage": "XDEBUG_MODE=coverage phpunit --testdox --testsuite unit --coverage-clover coverage.xml",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "lint": [
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    },
    "authors": [
        {
            "name": "Durable Workflow",
            "email": "support@durable-workflow.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "react/promise": "^2.9|^3.0",
        "apache/avro": "^1.12"
    },
    "require-dev": {
        "doctrine/dbal": "^3.7",
        "orchestra/testbench": "^8.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "symplify/easy-coding-standard": "^11.0"
    },
    "suggest": {
        "durable-workflow/sdk": "Framework-neutral client and remote-worker SDK for the standalone Durable Workflow server."
    },
    "extra": {
        "durable-workflow": {
            "product-train": "2.0.0-beta.4"
        },
        "laravel": {
            "providers": [
                "Workflow\\Providers\\WorkflowServiceProvider"
            ]
        }
    }
}
