[
  {
    "name": "single activity result",
    "scenario": "single-activity",
    "history": [
      {
        "event_type": "WorkflowStarted",
        "payload": {}
      },
      {
        "event_type": "ActivityCompleted",
        "payload": {
          "sequence": 1,
          "activity_type": "Tests\\Fixtures\\V2\\TestGreetingActivity",
          "result_value": "Hello, Ada!"
        }
      }
    ],
    "expected_state": {
      "stage": "completed",
      "name": null,
      "greeting": "Hello, Ada!",
      "approved": false,
      "version": -1,
      "version_result": null,
      "events": [
        "activity:Hello, Ada!"
      ]
    }
  },
  {
    "name": "signal then activity",
    "scenario": "signal-activity",
    "history": [
      {
        "event_type": "WorkflowStarted",
        "payload": {}
      },
      {
        "event_type": "SignalApplied",
        "payload": {
          "sequence": 1,
          "signal_name": "name-provided",
          "value_value": "Grace"
        }
      },
      {
        "event_type": "ActivityCompleted",
        "payload": {
          "sequence": 2,
          "activity_type": "Tests\\Fixtures\\V2\\TestGreetingActivity",
          "result_value": "Hello, Grace!"
        }
      }
    ],
    "expected_state": {
      "stage": "completed",
      "name": "Grace",
      "greeting": "Hello, Grace!",
      "approved": false,
      "version": -1,
      "version_result": null,
      "events": [
        "signal:Grace",
        "activity:Hello, Grace!"
      ]
    }
  },
  {
    "name": "wait condition satisfied by update",
    "scenario": "wait-condition",
    "history": [
      {
        "event_type": "WorkflowStarted",
        "payload": {}
      },
      {
        "event_type": "ConditionWaitOpened",
        "payload": {
          "sequence": 1,
          "condition_wait_id": "condition:1"
        }
      },
      {
        "event_type": "UpdateApplied",
        "payload": {
          "sequence": 1,
          "update_name": "approve",
          "arguments_value": [
            true
          ]
        }
      },
      {
        "event_type": "ConditionWaitSatisfied",
        "payload": {
          "sequence": 1,
          "condition_wait_id": "condition:1"
        }
      }
    ],
    "expected_state": {
      "stage": "approved",
      "name": null,
      "greeting": null,
      "approved": true,
      "version": -1,
      "version_result": null,
      "events": [
        "approved",
        "condition-satisfied"
      ]
    }
  },
  {
    "name": "version marker selects new path",
    "scenario": "version-marker",
    "history": [
      {
        "event_type": "WorkflowStarted",
        "payload": {}
      },
      {
        "event_type": "VersionMarkerRecorded",
        "payload": {
          "sequence": 1,
          "change_id": "golden-version",
          "version": 2,
          "min_supported": -1,
          "max_supported": 2
        }
      },
      {
        "event_type": "ActivityCompleted",
        "payload": {
          "sequence": 2,
          "activity_type": "Tests\\Fixtures\\V2\\TestVersionedActivityV3",
          "result_value": "v3_result"
        }
      }
    ],
    "expected_state": {
      "stage": "completed",
      "name": null,
      "greeting": null,
      "approved": false,
      "version": 2,
      "version_result": "v3_result",
      "events": [
        "version:2"
      ]
    }
  }
]
